{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "outDir": "out",
    "lib": ["ES2022"],
    "types": ["node", "vscode"],
    "strict": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "rootDir": "src",
    "skipLibCheck": true,
    "declaration": false
  },
  "include": ["src"],
  "exclude": ["node_modules", ".vscode-test", "dist"]
}
